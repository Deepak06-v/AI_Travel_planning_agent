# Google Cloud Project Configuration
# Get your GCP_PROJECT_ID from: https://console.cloud.google.com/
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_LOCATION=us-central1

# Vertex AI Model (usually pre-configured, but you can override)
# GEMINI_MODEL=gemini-2.5-flash

# OpenWeatherMap API Key
# Sign up free at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here
OPENWEATHER_TIMEOUT_SECONDS=15

# Google Maps API Key (optional, for route optimization)
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_MAPS_TIMEOUT_SECONDS=15

# User Memory Storage Path (optional)
# Defaults to ~/.travel_planner_user_memory.json
# TRAVEL_PLANNER_MEMORY_PATH=/custom/path/to/memory.json

# Logging Level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
